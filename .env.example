# ==============================================
# SENTINEL OMEGA - Environment Configuration
# ==============================================

# Server Configuration
NODE_ENV=production
PORT=8888
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:8888

# API Keys
CESIUM_ACCESS_TOKEN=your_cesium_token_here
AISSTREAM_API_KEY=your_aisstream_key_here

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ENABLE_TELEGRAM=false
BRIEFING_TO_TELEGRAM=false

# Feature Flags
ENABLE_AIS=true
ENABLE_ADSB=true
ENABLE_SATELLITES=false
ENABLE_DAILY_BRIEFING=true
ENABLE_PREDICTION=true

# ADS-B Configuration
ADSB_POLL_INTERVAL=15000
ADSB_API_URL=https://api.adsb.lol/v2/mil

# AIS Configuration
AIS_WEBSOCKET_URL=wss://stream.aisstream.io/v0/stream
AIS_HTTP_FALLBACK=true
AIS_HTTP_URL=https://api.aisstream.io/v0/vessels

# Performance Tuning
MAX_LIVE_ASSETS=200
MAX_TRAIL_POINTS=50
MAX_HISTORY_SIZE=2000
CLEANUP_INTERVAL=300000
STALE_ASSET_THRESHOLD=300000

# Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/sentinel.log

# Briefing Configuration
BRIEFING_TIME_HOUR=20
BRIEFING_TIME_MINUTE=0
BRIEFING_TIMEZONE=Asia/Jakarta
BRIEFING_OUTPUT_DIR=./briefings

# Data Sources Priority
PRIORITY_AIRCRAFT_TYPES=KC-135,RC-135,P-8,B-52,E-3,E-8,U-2,RQ-4
